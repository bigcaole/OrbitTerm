{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "OrbitTerm",
    "version": "0.1.18"
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true,
        "save": true
      },
      "shell": {
        "all": false,
        "open": "^https://(github\\.com|orbitterm\\.app|www\\.orbitterm\\.app)(/.*)?$"
      },
      "process": {
        "all": false,
        "relaunch": true
      }
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/bigcaole/OrbitTerm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNTk3NDRCRTE5QkUwMDUKUldRRjRKdmhTM1JaMDB3cU9PZTg3UVI0NDhaajdycEt0dktDMDlCblRZcmk3bWFSRXY5NnF1L3IK"
    },
    "bundle": {
      "active": true,
      "identifier": "com.orbitterm.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/AppIcon.png",
        "icons/AppIcon.icns",
        "icons/AppIcon.ico"
      ]
    },
    "windows": [
      {
        "title": "OrbitTerm · 轨连终端",
        "width": 1240,
        "height": 860,
        "resizable": true
      }
    ]
  }
}
